  "info": {
    "title": "pulmung API",
    "description": "",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "SignupDto": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "kakao",
              "google"
            ]
          },
          "accessToken": {
            "type": "string",
            "minLength": 1
          },
          "nickname": {
            "type": "string",
            "minLength": 2,
            "maxLength": 20
          },
          "platform": {
            "type": "string",
            "enum": [
              "web",
              "ios",
              "android"
            ]
          },
          "deviceName": {
            "type": "string"
          }
        },
        "required": [
          "provider",
          "accessToken",
          "nickname",
          "platform"
        ]
      },
      "AuthTokensDto_Output": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "accessToken",
          "refreshToken"
        ],
        "additionalProperties": false
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "kakao",
              "google"
            ]
          },
          "accessToken": {
            "type": "string",
            "minLength": 1
          },
          "platform": {
            "type": "string",
            "enum": [
              "web",
              "ios",
              "android"
            ]
          },
          "deviceName": {
            "type": "string"
          }
        },
        "required": [
          "provider",
          "accessToken",
          "platform"
        ]
      },
      "RefreshTokenDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "CreateFileUploadDto": {
        "type": "object",
        "properties": {
          "purpose": {
            "type": "string",
            "enum": [
              "plant-image"
            ]
          },
          "contentType": {
            "type": "string",
            "minLength": 1,
            "example": "image/jpeg"
          },
          "size": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": [
          "purpose",
          "contentType"
        ]
      },
      "FileUploadTargetDto_Output": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "업로드 후 도메인 리소스 생성 요청(예: 식물 등록)에 첨부할 불투명 key",
            "example": "plant-image/0198c5b2-2f74-7abc-8def-0123456789ab.jpg"
          },
          "upload": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "format": "uri",
                "description": "S3 presigned POST 대상 URL"
              },
              "fields": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                },
                "description": "POST form에 그대로 실어야 하는 서명 필드들"
              },
              "expiresAt": {
                "type": "string",
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                "description": "presign 만료 시각"
              }
            },
            "required": [
              "url",
              "fields",
              "expiresAt"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "key",
          "upload"
        ],
        "additionalProperties": false
      },
      "CreatePlantDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "example": "몬스테라 알보"
          },
          "images": {
            "minItems": 1,
            "maxItems": 10,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string",
                  "minLength": 1,
                  "example": "plant-image/0198c5b2-2f74-7abc-8def-0123456789ab.jpg"
                },
                "width": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "height": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                }
              },
              "required": [
                "key"
              ]
            }
          },
          "genus": {
            "description": "속 — 자유 텍스트(genera 사전은 제안 소스일 뿐)",
            "example": "Monstera",
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "species": {
            "description": "종 — 자유 텍스트",
            "example": "deliciosa",
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "category": {
            "type": "string",
            "enum": [
              "관엽",
              "다육",
              "선인장",
              "괴근",
              "난초",
              "허브",
              "식충",
              "수생"
            ]
          }
        },
        "required": [
          "name",
          "images"
        ]
      },
      "PlantDto_Output": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
          },
          "name": {
            "type": "string"
          },
          "images": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string"
                },
                "width": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "height": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                }
              },
              "required": [
                "key"
              ],
              "additionalProperties": false
            }
          },
          "genus": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "species": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "category": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "관엽",
                  "다육",
                  "선인장",
                  "괴근",
                  "난초",
                  "허브",
                  "식충",
                  "수생"
                ]
              },
              {
                "type": "null"
              }
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
          }
        },
        "required": [
          "id",
          "name",
          "images",
          "genus",
          "species",
          "category",
          "createdAt"
        ],
        "additionalProperties": false
      }
    }
  }
}
