  "components": {
    "schemas": {
      "SignupDto": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "kakao",
              "google"
            ]
          },
          "accessToken": {
            "type": "string",
            "minLength": 1
          },
          "nickname": {
            "type": "string",
            "minLength": 2,
            "maxLength": 20
          },
          "platform": {
            "type": "string",
            "enum": [
              "web",
              "ios",
              "android"
            ]
          },
          "deviceName": {
            "type": "string"
          }
        },
        "required": [
          "provider",
          "accessToken",
          "nickname",
          "platform"
        ]
      },
      "AuthTokensDto_Output": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "accessToken",
          "refreshToken"
        ],
        "additionalProperties": false
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
