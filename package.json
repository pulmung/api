    "@nestjs/swagger": "^11.4.4",
    "dotenv": "^17.4.2",
    "drizzle-orm": "1.0.0-rc.3",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.4.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuidv7": "^1.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.24",
    "@swc-node/register": "^1.11.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.40",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.7",
    "chokidar": "^5.0.0",
